# === Git LFS tracking ===
# Track large binary assets via LFS to reduce local clone size.
# After adding this file, run: git lfs install && git lfs migrate import --include="*.png,*.jpg,*.gif,*.svg"
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
*.svg filter=lfs diff=lfs merge=lfs -text
*.ico filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text

# Translation cache can grow large — track via LFS
scripts/.translation_cache/index.json filter=lfs diff=lfs merge=lfs -text

# === Linguist overrides ===
docs/** linguist-documentation
site/** linguist-generated
